# 줄바꿈 LF 고정 — core.autocrlf 무관하게 저장소 일관성 유지 (CRLF churn 방지)
* text=auto eol=lf

# 명시적 텍스트 타입 (LF)
*.dart   text eol=lf
*.py     text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.xml    text eol=lf
*.gradle text eol=lf
*.kt     text eol=lf
*.kts    text eol=lf
*.pro    text eol=lf
*.sh     text eol=lf
*.txt    text eol=lf

# Windows 배치는 CRLF 유지
*.bat    text eol=crlf
*.cmd    text eol=crlf

# 바이너리 (정규화 금지)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.ttf  binary
*.otf  binary
*.jar  binary
*.keystore binary
*.jks  binary
*.apk  binary
*.aab  binary
*.ait  binary
